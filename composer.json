{
    "name": "usernamn0tavailable/crabmagick",
    "description": "Pure-Rust libvips replacement as a self-contained PHP package. Bundles a pre-built native extension — activate with PHP_INI_SCAN_DIR, no sudo required.",
    "type": "library",
    "license": "MIT",
    "keywords": ["image", "rust", "vips", "webp", "jxl", "jpeg", "iiif", "extension"],
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "Crabmagick\\": "src/"
        },
        "files": [
            "src/bootstrap.php"
        ]
    },
    "scripts": {
        "post-install-cmd": ["Crabmagick\\Installer::postInstall"],
        "post-update-cmd":  ["Crabmagick\\Installer::postInstall"]
    }
}

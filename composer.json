{
    "name": "usernamn0tavailable/crabmagick",
    "description": "Pure-Rust image processing for PHP — zero config. A daemon is spawned automatically on first use. No php.ini changes, no sudo, just composer require.",
    "type": "library",
    "license": "MIT",
    "keywords": ["image", "rust", "vips", "webp", "jxl", "jpeg", "iiif", "daemon"],
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "Crabmagick\\": "src/"
        },
        "files": [
            "src/bootstrap.php",
            "src/functions.php"
        ]
    },
    "scripts": {
        "post-install-cmd": ["Crabmagick\\Installer::postInstall"],
        "post-update-cmd":  ["Crabmagick\\Installer::postInstall"]
    }
}

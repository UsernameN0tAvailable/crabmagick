{
    "name": "usernamn0tavailable/crabmagick",
    "description": "Pure-Rust image processing for PHP — bundled native library loaded via PHP FFI. Zero C dependencies, no php.ini extension= line needed.",
    "type": "library",
    "license": "MIT",
    "keywords": ["image", "rust", "vips", "webp", "jxl", "jpeg", "iiif", "ffi"],
    "require": {
        "php": ">=8.1",
        "ext-ffi": "*"
    },
    "autoload": {
        "psr-4": {
            "Crabmagick\\": "src/"
        },
        "files": [
            "src/bootstrap.php",
            "src/functions.php"
        ]
    },
    "scripts": {
        "post-install-cmd": ["Crabmagick\\CrabmagickInstaller::postInstall"],
        "post-update-cmd": ["Crabmagick\\CrabmagickInstaller::postInstall"]
    }
}
